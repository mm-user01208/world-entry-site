6:["$","div",null,{"className":"border-l-4 border-gray-800 pl-6","children":[["$","h3",null,{"className":"font-serif-country text-xl font-bold text-gray-800 mb-3","children":"South Korea"}],["$","p",null,{"className":"text-gray-700 leading-relaxed mb-3","children":"韓国へ渡航する際は、渡航者の国籍や渡航目的、滞在期間に応じて、ビザまたは電子渡航認証（K-ETA）の取得が必要となる場合があります。観光や短期商用などを目的とする一部の国・地域の渡航者は、K-ETA（韓国電子渡航認証）を利用できる制度が設けられています。"}],["$","$L2",null,{"href":"/south-korea","className":"text-blue-600 hover:underline text-sm font-medium","children":"会社情報 →"}]]}]
